{
  "name": "placeholder-platform",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check:boundaries": "node tools/scripts/check-boundaries.mjs",
    "check:openapi": "node tools/scripts/validate-openapi.mjs",
    "check:env:api": "npm -w @placeholder/student-api run validate:env",
    "check:env:worker": "npm -w @placeholder/judge-worker run validate:env",
    "check:env": "npm run check:env:api && npm run check:env:worker",
    "typecheck": "npm run -ws --if-present typecheck",
    "lint": "npm run check:boundaries && npm run check:openapi && npm run -ws lint",
    "test": "npm run -ws test",
    "build": "npm run -ws build",
    "quality": "npm run lint && npm run test && npm run build",
    "local:up": "node tools/scripts/local-up.mjs",
    "local:down": "docker compose -f deploy/local/docker-compose.yml down -v",
    "local:ps": "docker compose -f deploy/local/docker-compose.yml ps",
    "local:reset": "node tools/scripts/local-reset.mjs",
    "local:db:migrate": "node tools/scripts/local-db-migrate.mjs",
    "local:db:seed": "node tools/scripts/local-db-seed.mjs",
    "local:db:setup": "npm run local:db:migrate && npm run local:db:seed",
    "local:problems:cleanup": "node tools/scripts/local-problems-cleanup.mjs",
    "local:problems:verify": "node tools/scripts/local-problems-verify.mjs",
    "import:problems": "node tools/scripts/import-problems.mjs",
    "smoke:local": "node tools/scripts/local-smoke.mjs",
    "api:start": "PORT=${PORT:-3100} DATABASE_URL=${DATABASE_URL:-postgresql://oj:oj@127.0.0.1:5432/oj} npm -w @placeholder/student-api run start",
    "worker:start": "npm -w @placeholder/judge-worker run start",
    "extension:package": "mkdir -p dist && npm -w placeholder-extension run package:vsix && cp apps/vscode-extension/placeholder-extension-$(node -p \"require('./apps/vscode-extension/package.json').version\").vsix dist/placeholder-extension.vsix"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.2"
  }
}
