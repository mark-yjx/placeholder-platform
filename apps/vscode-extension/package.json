{
  "name": "placeholder-extension",
  "displayName": "Placeholder Practice",
  "description": "Local-first Placeholder Practice workflow for login, problem browsing, starter files, submission polling, and result inspection in VS Code.",
  "private": true,
  "publisher": "placeholder",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "icon": "media/icon.png",
  "categories": [
    "Education",
    "Programming Languages"
  ],
  "keywords": [
    "online-judge",
    "comp9021",
    "python",
    "practice",
    "education"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mark-yjx/placeholder-platform.git"
  },
  "homepage": "https://github.com/mark-yjx/placeholder-platform",
  "bugs": {
    "url": "https://github.com/mark-yjx/placeholder-platform/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onUri",
    "onCommand:oj.account.show",
    "onCommand:oj.logout",
    "onCommand:oj.login",
    "onCommand:oj.practice.fetchProblems",
    "onCommand:oj.practice.submitCode",
    "onCommand:oj.practice.submitCurrentFile",
    "onCommand:oj.practice.runPublicTests",
    "onCommand:oj.practice.viewResult",
    "onCommand:oj.practice.cancelPolling",
    "onCommand:oj.practice.selectSubmission",
    "onView:ojPracticeHome",
    "onView:ojProblems",
    "onView:ojSubmissions",
    "onView:ojSubmissionDetail",
    "onCommand:oj.engagement.favoriteProblem",
    "onCommand:oj.engagement.submitReview",
    "onCommand:oj.stats.show",
    "onCommand:oj.ranking.show"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ojSidebar",
          "title": "Placeholder",
          "icon": "media/icon.png"
        }
      ],
      "panel": [
        {
          "id": "ojPanel",
          "title": "Placeholder Judge",
          "icon": "media/icon.png"
        }
      ]
    },
    "configuration": {
      "title": "Placeholder Practice",
      "properties": {
        "oj.apiBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3100",
          "description": "Base URL for the Placeholder student API used by the extension."
        },
        "oj.requestTimeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1,
          "description": "HTTP request timeout in milliseconds for Placeholder student API requests. Tokens are stored locally in VS Code SecretStorage."
        }
      }
    },
    "commands": [
      {
        "command": "oj.account.show",
        "title": "Placeholder Practice: Open Account",
        "icon": {
          "light": "media/account-light.svg",
          "dark": "media/account-dark.svg"
        }
      },
      {
        "command": "oj.logout",
        "title": "Placeholder Practice: Logout"
      },
      {
        "command": "oj.login",
        "title": "Placeholder Practice: Login"
      },
      {
        "command": "oj.practice.fetchProblems",
        "title": "Placeholder Practice: Fetch Problems",
        "icon": {
          "light": "media/fetch-problems-light.svg",
          "dark": "media/fetch-problems-dark.svg"
        }
      },
      {
        "command": "oj.practice.submitCode",
        "title": "Placeholder Practice: Submit Code"
      },
      {
        "command": "oj.practice.submitCurrentFile",
        "title": "Placeholder Practice: Submit Current File"
      },
      {
        "command": "oj.practice.runPublicTests",
        "title": "Placeholder Practice: Run Public Tests"
      },
      {
        "command": "oj.practice.viewResult",
        "title": "Placeholder Practice: View Result"
      },
      {
        "command": "oj.practice.cancelPolling",
        "title": "Placeholder Practice: Cancel Polling"
      },
      {
        "command": "oj.practice.selectSubmission",
        "title": "Placeholder Practice: Show Submission Detail"
      },
      {
        "command": "oj.engagement.favoriteProblem",
        "title": "Placeholder Practice: Favorite Problem"
      },
      {
        "command": "oj.engagement.submitReview",
        "title": "Placeholder Practice: Submit Review"
      },
      {
        "command": "oj.stats.show",
        "title": "Placeholder Practice: Show Public Stats"
      },
      {
        "command": "oj.ranking.show",
        "title": "Placeholder Practice: Show Public Ranking"
      }
    ],
    "views": {
      "ojSidebar": [
        {
          "id": "ojPracticeHome",
          "name": "Placeholder Practice",
          "type": "webview",
          "when": "oj.practice.homeVisible"
        },
        {
          "id": "ojProblems",
          "name": "Problems",
          "when": "oj.practice.viewsReady"
        }
      ],
      "ojPanel": [
        {
          "id": "ojSubmissions",
          "name": "Submissions",
          "when": "oj.practice.viewsReady"
        },
        {
          "id": "ojSubmissionDetail",
          "name": "Submission Detail",
          "type": "webview",
          "when": "oj.practice.viewsReady"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "oj.practice.fetchProblems",
          "when": "view == ojProblems && oj.practice.viewsReady",
          "group": "navigation@1"
        },
        {
          "command": "oj.account.show",
          "when": "view == ojProblems && oj.practice.viewsReady",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint placeholder-extension')\"",
    "test": "rm -rf .tmp-test && tsc -p tsconfig.test.json && node --test .tmp-test/__tests__/*.test.js",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "package:vsix": "npm run build && node ../../node_modules/@vscode/vsce/vsce package --no-dependencies --out placeholder-extension-$(node -p \"require('./package.json').version\").vsix"
  }
}
