{
  "name": "oj-vscode-extension",
  "displayName": "OJ VSCode",
  "description": "Local-first COMP9021 online judge workflow for login, problem browsing, starter files, submission polling, and result inspection in VS Code.",
  "private": true,
  "publisher": "local",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "icon": "media/icon.png",
  "categories": [
    "Education",
    "Programming Languages"
  ],
  "keywords": [
    "online-judge",
    "comp9021",
    "python",
    "practice",
    "education"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mark-yjx/comp9021-oj.git"
  },
  "homepage": "https://github.com/mark-yjx/comp9021-oj",
  "bugs": {
    "url": "https://github.com/mark-yjx/comp9021-oj/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onUri",
    "onCommand:oj.account.show",
    "onCommand:oj.logout",
    "onCommand:oj.login",
    "onCommand:oj.signup",
    "onCommand:oj.practice.fetchProblems",
    "onCommand:oj.practice.submitCode",
    "onCommand:oj.practice.submitCurrentFile",
    "onCommand:oj.practice.runPublicTests",
    "onCommand:oj.practice.viewResult",
    "onCommand:oj.practice.cancelPolling",
    "onCommand:oj.practice.selectSubmission",
    "onView:ojProblems",
    "onView:ojSubmissions",
    "onView:ojProblemDetail",
    "onView:ojSubmissionDetail",
    "onCommand:oj.engagement.favoriteProblem",
    "onCommand:oj.engagement.submitReview",
    "onCommand:oj.stats.show",
    "onCommand:oj.ranking.show"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ojSidebar",
          "title": "OJ",
          "icon": "media/icon.png"
        }
      ],
      "panel": [
        {
          "id": "ojPanel",
          "title": "OJ Results",
          "icon": "media/icon.png"
        }
      ]
    },
    "configuration": {
      "title": "OJ VSCode",
      "properties": {
        "oj.apiBaseUrl": {
          "type": "string",
          "default": "http://localhost:3100",
          "description": "Base URL for the OJ API used by the extension."
        },
        "oj.requestTimeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1,
          "description": "HTTP request timeout in milliseconds for OJ API requests. Tokens are stored locally in VS Code SecretStorage."
        }
      }
    },
    "commands": [
      {
        "command": "oj.account.show",
        "title": "OJ: Open Account"
      },
      {
        "command": "oj.logout",
        "title": "OJ: Logout"
      },
      {
        "command": "oj.login",
        "title": "OJ: Sign In"
      },
      {
        "command": "oj.signup",
        "title": "OJ: Sign Up"
      },
      {
        "command": "oj.practice.fetchProblems",
        "title": "OJ: Fetch Problems"
      },
      {
        "command": "oj.practice.submitCode",
        "title": "OJ: Submit Code"
      },
      {
        "command": "oj.practice.submitCurrentFile",
        "title": "OJ: Submit Current File"
      },
      {
        "command": "oj.practice.runPublicTests",
        "title": "OJ: Run Public Tests"
      },
      {
        "command": "oj.practice.viewResult",
        "title": "OJ: View Result"
      },
      {
        "command": "oj.practice.cancelPolling",
        "title": "OJ: Cancel Polling"
      },
      {
        "command": "oj.practice.selectSubmission",
        "title": "OJ: Show Submission Detail"
      },
      {
        "command": "oj.engagement.favoriteProblem",
        "title": "OJ: Favorite Problem"
      },
      {
        "command": "oj.engagement.submitReview",
        "title": "OJ: Submit Review"
      },
      {
        "command": "oj.stats.show",
        "title": "OJ: Show Public Stats"
      },
      {
        "command": "oj.ranking.show",
        "title": "OJ: Show Public Ranking"
      }
    ],
    "views": {
      "ojSidebar": [
        {
          "id": "ojProblems",
          "name": "Problems"
        },
        {
          "id": "ojProblemDetail",
          "name": "Problem Detail",
          "type": "webview"
        }
      ],
      "ojPanel": [
        {
          "id": "ojSubmissions",
          "name": "Submissions"
        },
        {
          "id": "ojSubmissionDetail",
          "name": "Submission Detail",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "oj.practice.fetchProblems",
          "when": "view == ojProblems",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint @apps/vscode-extension')\"",
    "test": "rm -rf .tmp-test && tsc -p tsconfig.test.json && node --test .tmp-test/__tests__/*.test.js",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "package:vsix": "npm run build && node ../../node_modules/@vscode/vsce/vsce package --no-dependencies --out oj-vscode-extension-$(node -p \"require('./package.json').version\").vsix"
  }
}
