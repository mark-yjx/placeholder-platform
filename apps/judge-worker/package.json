{
  "name": "@apps/judge-worker",
  "private": true,
  "version": "0.0.0",
  "dependencies": {
    "@packages/contracts": "*",
    "@packages/infrastructure": "*"
  },
  "scripts": {
    "validate:env": "node ../../tools/scripts/validate-env.mjs worker",
    "start": "node ./worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint @apps/judge-worker')\"",
    "test": "rm -rf .tmp-test && tsc -p tsconfig.test.json && node --test .tmp-test/sandbox/__tests__/*.test.js .tmp-test/runner/__tests__/*.test.js",
    "build": "node -e \"console.log('build @apps/judge-worker')\""
  }
}
