{
  "name": "@placeholder/student-api",
  "private": true,
  "version": "0.0.0",
  "dependencies": {
    "@placeholder/application": "*",
    "@placeholder/domain": "*",
    "@placeholder/infrastructure": "*"
  },
  "scripts": {
    "validate:env": "node ../../tools/scripts/validate-env.mjs api",
    "start": "node ./server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint @placeholder/student-api')\"",
    "test": "rm -rf .tmp-test && tsc -p tsconfig.test.json && node --test .tmp-test/__tests__/*.test.js",
    "build": "node -e \"console.log('build @placeholder/student-api')\""
  }
}
