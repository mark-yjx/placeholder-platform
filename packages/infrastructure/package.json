{
  "name": "@placeholder/infrastructure",
  "private": true,
  "version": "0.0.0",
  "dependencies": {
    "@placeholder/application": "*",
    "@placeholder/contracts": "*",
    "@placeholder/domain": "*"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
